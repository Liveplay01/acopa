# ─────────────────────────────────────────────────────────────
# ACOPA Website – Umgebungsvariablen
# Kopieren als: config/.env
# ─────────────────────────────────────────────────────────────

# Server
PORT=3000

# Admin-Panel Passwort
# Bitte vor Deployment ändern!
ADMIN_PASSWORD=acopa2026

# Session Secret (mind. 32 Zeichen, zufällig)
# Generator: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=bitte-aendern-32-zufaellige-zeichen-hier

# ─── E-Mail (Kontaktformular) ─────────────────────────────────
# Empfänger-Adresse für Kontaktanfragen
CONTACT_TO_EMAIL=info@acopa.de

# SMTP-Zugangsdaten
# Option A: Gmail mit App-Passwort
#   1. Google-Konto → Sicherheit → 2-Faktor-Auth aktivieren
#   2. Google-Konto → Sicherheit → App-Passwörter → "Mail" erstellen
#   3. Das 16-stellige Passwort hier eintragen
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ihre-adresse@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Option B: Eigener Mailserver / Mailgun / Brevo etc.
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@mg.acopa.de
# SMTP_PASS=ihr-api-key
