# ============================================================
# ACOPA Website – Umgebungsvariablen
# Kopiere diese Datei nach config/.env und fülle die Werte aus.
# WICHTIG: config/.env niemals ins Git committen!
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=3000

# ── Admin-Zugang ─────────────────────────────────────────────
# Passwort für das Admin-Panel unter /admin
ADMIN_PASSWORD=acopa2026

# Session-Secret: mindestens 32 zufällige Zeichen (z.B. openssl rand -hex 32)
SESSION_SECRET=bitte-aendern-mit-langem-zufalls-string

# ── SMTP / E-Mail (für Kontaktformular) ──────────────────────
# Ohne diese Variablen werden Kontaktanfragen nur ins Terminal geloggt.
#
# Option A – Gmail mit App-Passwort (einfachste Lösung):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=deine-adresse@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx   (Google App-Passwort, kein normales Passwort)
#
# Option B – Eigener Mailserver (z.B. Hetzner, Strato, IONOS):
#   SMTP_HOST=mail.deine-domain.de
#   SMTP_PORT=587
#   SMTP_USER=info@deine-domain.de
#   SMTP_PASS=dein-passwort
#
# Option C – Transaktionsmail-Dienst (Brevo, Mailgun, Postmark):
#   Jeweilige SMTP-Zugangsdaten aus dem Dashboard des Dienstes eintragen

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=deine-adresse@gmail.com
SMTP_PASS=app-passwort-hier-eintragen

# E-Mail-Adresse, an die Kontaktanfragen zugestellt werden
CONTACT_TO_EMAIL=info@acopa.de
