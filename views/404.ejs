<%- include('partials/_head', { title: '404 – Seite nicht gefunden | ACOPA GmbH', description: 'Diese Seite konnte nicht gefunden werden.' }) %>
<%- include('partials/_nav') %>

<main id="main-content">

  <section style="min-height:70vh;display:flex;align-items:center;justify-content:center;padding:4rem 1rem;text-align:center;position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;background:var(--color-bg);z-index:0;"></div>
    <div style="position:relative;z-index:1;max-width:560px;margin:0 auto;">
      <div style="font-family:var(--font-mono);font-size:clamp(5rem,15vw,9rem);font-weight:900;line-height:1;color:var(--color-primary);opacity:0.15;margin-bottom:-1rem;user-select:none;">404</div>
      <h1 style="font-family:var(--font-display);font-size:clamp(2rem,5vw,3rem);font-weight:400;color:var(--color-foreground);margin-bottom:1rem;">Seite nicht gefunden</h1>
      <p style="font-size:var(--text-base);color:var(--color-gray-600);line-height:1.7;margin-bottom:2.5rem;">
        Die gesuchte Seite existiert nicht oder wurde verschoben. Vielleicht hilft Ihnen einer der folgenden Links weiter.
      </p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href="/" class="btn btn-primary">Zur Startseite</a>
        <a href="/service" class="btn btn-outline">Unsere Leistungen</a>
        <a href="/#contact" class="btn btn-outline">Kontakt</a>
      </div>
    </div>
  </section>

</main>

<%- include('partials/_footer') %>
