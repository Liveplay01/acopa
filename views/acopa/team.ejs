<%- include('../partials/_head', {
  title: 'Unser Team – ACOPA GmbH',
  description: 'Lernen Sie das ACOPA Expertenteam kennen: Erfahrene SAP-Consultants, Digitalisierungsexperten und Strategieberater mit über 15 Jahren gemeinsamer Beratungspraxis.',
  ogPath: '/acopa/team'
}) %>
<%- include('../partials/_nav') %>

<main id="main-content">

  <section class="page-hero">
    <div class="page-hero-bg" style="background-image:url('https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=1920&q=80')"></div>
    <div class="page-hero-overlay"></div>
    <div class="page-hero-accent"></div>
    <div class="page-hero-shape"></div>
    <div class="container">
      <nav class="breadcrumb"><a href="/">Home</a><span>/</span><a href="/acopa">ACOPA</a><span>/</span><span>Team</span></nav>
      <p class="section-eyebrow" style="color:var(--color-primary);margin-bottom:1rem;">ACOPA</p>
      <h1 class="page-hero-title">Unser <span class="accent">Team.</span></h1>
      <p class="page-hero-sub">Hinter ACOPA stehen Menschen mit Leidenschaft, Expertise und dem echten Willen, Ihren Projekterfolg sicherzustellen – persönlich, direkt und auf Augenhöhe.</p>
    </div>
  </section>

  <!-- Sub-Navigation -->
  <section style="background:var(--color-surface);border-bottom:1px solid var(--color-gray-200);padding:1.25rem 0;">
    <div class="container">
      <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
        <a href="/acopa" class="btn btn-outline" style="font-size:var(--text-xs);">Essenz</a>
        <a href="/acopa/netzwerk" class="btn btn-outline" style="font-size:var(--text-xs);">Netzwerk</a>
        <a href="/acopa/team" class="btn btn-primary" style="font-size:var(--text-xs);">Team</a>
        <a href="/acopa/erfolgsgeschichte" class="btn btn-outline" style="font-size:var(--text-xs);">Erfolgsgeschichte</a>
        <a href="/acopa/referenzen" class="btn btn-outline" style="font-size:var(--text-xs);">Referenzen</a>
      </div>
    </div>
  </section>

  <!-- Intro -->
  <section class="content-section">
    <div class="container">
      <div class="section-header reveal-up" style="max-width:700px;margin:0 auto;text-align:center;">
        <p class="section-eyebrow" style="justify-content:center;">Warum Gesichter zählen</p>
        <h2 class="section-headline">Experten, die Sie persönlich begleiten</h2>
        <p class="section-sub">Bei ACOPA arbeiten Sie nie mit einer anonymen Beraterbank. Sie kennen Ihre Ansprechpartner vom ersten Gespräch bis zum Go-Live – direkt, verbindlich, ohne Junior-Staffing-Pyramide.</p>
      </div>
    </div>
  </section>

  <!-- Team Members -->
  <section class="content-section content-section--alt">
    <div class="container">

      <% if (members && members.length > 0) { %>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:2.5rem;">
        <% members.forEach(function(member) { %>
        <div class="reveal-up" style="background:var(--color-surface);border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow-card);transition:box-shadow 0.3s var(--ease-out-expo);" onmouseover="this.style.boxShadow='var(--shadow-hover)'" onmouseout="this.style.boxShadow='var(--shadow-card)'">
          <% if (member.imageUrl) { %>
          <div style="aspect-ratio:4/3;overflow:hidden;">
            <img src="<%= member.imageUrl %>" alt="<%= member.name %>" loading="lazy"
              style="width:100%;height:100%;object-fit:cover;transition:transform 0.5s var(--ease-out-expo);"
              onmouseover="this.style.transform='scale(1.04)'" onmouseout="this.style.transform='scale(1)'">
          </div>
          <% } else { %>
          <div style="aspect-ratio:4/3;background:var(--color-gray-200);display:flex;align-items:center;justify-content:center;">
            <div style="width:80px;height:80px;border-radius:50%;background:var(--color-primary);display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:800;color:#fff;font-family:var(--font-mono);">
              <%= member.name.split(' ').map(n => n[0]).join('').substring(0,2).toUpperCase() %>
            </div>
          </div>
          <% } %>
          <div style="padding:1.75rem;">
            <div style="font-family:var(--font-display);font-size:1.25rem;font-weight:400;color:var(--color-foreground);margin-bottom:0.25rem;"><%= member.name %></div>
            <div style="font-size:var(--text-sm);font-weight:600;color:var(--color-primary);font-family:var(--font-mono);letter-spacing:0.04em;margin-bottom:1rem;"><%= member.role %></div>
            <% if (member.bio) { %>
            <p style="font-size:var(--text-sm);color:var(--color-gray-600);line-height:1.7;"><%= member.bio %></p>
            <% } %>
            <% if (member.linkedin) { %>
            <a href="<%= member.linkedin %>" target="_blank" rel="noopener noreferrer"
              style="display:inline-flex;align-items:center;gap:0.4rem;margin-top:1.25rem;font-size:var(--text-xs);font-weight:600;color:var(--color-gray-600);text-decoration:none;transition:color 0.2s;"
              onmouseover="this.style.color='var(--color-primary)'" onmouseout="this.style.color='var(--color-gray-600)'">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
              LinkedIn
            </a>
            <% } %>
          </div>
        </div>
        <% }); %>
      </div>
      <% } else { %>
      <div style="text-align:center;padding:4rem 0;color:var(--color-gray-400);">
        <p>Team-Profile werden in Kürze ergänzt.</p>
      </div>
      <% } %>

    </div>
  </section>

  <!-- Network hint -->
  <section class="content-section">
    <div class="container">
      <div class="content-grid reveal-up">
        <div>
          <p class="section-eyebrow">Das ACOPA Netzwerk</p>
          <h2 class="section-headline">Mehr als ein Team – ein Netzwerk von 50+ Experten</h2>
          <p class="section-sub">Hinter unserem Kernteam steht ein erprobtes Netzwerk spezialisierter Consultants. Je nach Projektanforderung bringen wir genau die Expertise ein, die Ihr Projekt braucht – keine Generalist·innen, sondern echte Spezialist·innen.</p>
          <div style="margin-top:2rem;display:flex;gap:1rem;flex-wrap:wrap;">
            <a href="/acopa/netzwerk" class="btn btn-outline">Netzwerk kennenlernen</a>
            <a href="/#contact" class="btn btn-primary">Gespräch anfragen</a>
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
          <div style="background:var(--color-surface);border-radius:var(--radius-md);padding:1.5rem;text-align:center;box-shadow:var(--shadow-card);">
            <div style="font-family:var(--font-mono);font-size:2.5rem;font-weight:700;color:var(--color-primary);">50+</div>
            <div style="font-size:var(--text-sm);color:var(--color-gray-600);margin-top:0.25rem;">Experten im Netzwerk</div>
          </div>
          <div style="background:var(--color-surface);border-radius:var(--radius-md);padding:1.5rem;text-align:center;box-shadow:var(--shadow-card);">
            <div style="font-family:var(--font-mono);font-size:2.5rem;font-weight:700;color:var(--color-primary);">200+</div>
            <div style="font-size:var(--text-sm);color:var(--color-gray-600);margin-top:0.25rem;">Abgeschlossene Projekte</div>
          </div>
          <div style="background:var(--color-surface);border-radius:var(--radius-md);padding:1.5rem;text-align:center;box-shadow:var(--shadow-card);">
            <div style="font-family:var(--font-mono);font-size:2.5rem;font-weight:700;color:var(--color-primary);">15+</div>
            <div style="font-size:var(--text-sm);color:var(--color-gray-600);margin-top:0.25rem;">Jahre Erfahrung</div>
          </div>
          <div style="background:var(--color-surface);border-radius:var(--radius-md);padding:1.5rem;text-align:center;box-shadow:var(--shadow-card);">
            <div style="font-family:var(--font-mono);font-size:2.5rem;font-weight:700;color:var(--color-primary);">30+</div>
            <div style="font-size:var(--text-sm);color:var(--color-gray-600);margin-top:0.25rem;">Zufriedene Kunden</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <p class="section-eyebrow cta-eyebrow">Ihr Ansprechpartner</p>
      <h2 class="cta-title">Lernen Sie uns persönlich kennen.</h2>
      <p class="cta-sub">Vereinbaren Sie ein unverbindliches Erstgespräch – direkt mit einem unserer Experten, ohne Vertriebsumweg.</p>
      <div class="cta-buttons">
        <a href="/#contact" class="btn btn-primary">Gespräch anfragen</a>
        <a href="/acopa/referenzen" class="btn btn-ghost">Referenzen ansehen</a>
      </div>
    </div>
  </section>

</main>

<%- include('../partials/_footer') %>
