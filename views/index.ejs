    <div class="hero-overlay" role="presentation"></div>
    <div class="hero-accent"        role="presentation"></div>
    <div class="hero-accent-shape"  role="presentation"></div>
    <div class="hero-dot-grid"      role="presentation"></div>

    <div class="container hero-content">
      <p class="hero-eyebrow" id="heroEyebrow" data-i18n="hero.eyebrow">Managementberatung & IT-Consulting</p>

      <h1 class="hero-headline" id="heroHeadline">
        <span class="hero-line"><span class="hero-line-inner"
          data-cms-de="<%= (pages.homepage.heroTitle && pages.homepage.heroTitle.de) || 'Mehrwert durch' %>"
          data-cms-en="<%= (pages.homepage.heroTitle && pages.homepage.heroTitle.en) || 'Value through' %>"
        ><%= (pages.homepage.heroTitle && pages.homepage.heroTitle.de) || 'Mehrwert durch' %></span></span>
        <span class="hero-line"><span class="hero-line-inner accent"
          data-cms-de="<%= (pages.homepage.heroTitleAccent && pages.homepage.heroTitleAccent.de) || 'digitale Prozesse.' %>"
          data-cms-en="<%= (pages.homepage.heroTitleAccent && pages.homepage.heroTitleAccent.en) || 'digital processes.' %>"
        ><%= (pages.homepage.heroTitleAccent && pages.homepage.heroTitleAccent.de) || 'digitale Prozesse.' %></span></span>
      </h1>

      <p class="hero-sub" id="heroSub"
        data-cms-de="<%= (pages.homepage.heroSubtitle && pages.homepage.heroSubtitle.de) || 'Als innovatives Expertennetzwerk transformieren wir mittelständische und Großunternehmen mit maßgeschneiderten SAP-, Digitalisierungs- und Beratungslösungen.' %>"
        data-cms-en="<%= (pages.homepage.heroSubtitle && pages.homepage.heroSubtitle.en) || 'As an innovative expert network, we transform mid-size and large enterprises with tailored SAP, digitalization, and consulting solutions.' %>"
      ><%= (pages.homepage.heroSubtitle && pages.homepage.heroSubtitle.de) || 'Als innovatives Expertennetzwerk transformieren wir mittelständische und Großunternehmen mit maßgeschneiderten SAP-, Digitalisierungs- und Beratungslösungen.' %></p>

      <div class="hero-ctas" id="heroCtas">
        <a href="/#contact" class="btn btn-primary" data-i18n="hero.cta1">Kostenlose Beratung</a>
        <% if (settings && settings.company && settings.company.calendlyUrl) { %>
        <a href="<%= settings.company.calendlyUrl %>" target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
          Termin buchen
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
        </a>
        <% } else { %>
        <a href="/service"  class="btn btn-ghost"   data-i18n="hero.cta2">Unsere Leistungen</a>
        <% } %>
      </div>
      <div class="hero-trust" aria-label="Vertrauenssignale">
        <span class="hero-trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          15+ Jahre Erfahrung
        </span>
        <span class="hero-trust-sep" aria-hidden="true">·</span>
        <span class="hero-trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          200+ Projekte
        </span>
        <span class="hero-trust-sep" aria-hidden="true">·</span>
        <span class="hero-trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          SAP Silver Partner
        </span>
      </div>
    </div>

    <div class="hero-scroll" aria-hidden="true">
      <div class="hero-scroll-line"></div>
      <span>Scroll</span>
    </div>
  </section>

