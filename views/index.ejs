  <!-- ── CONTACT ────────────────────────────────────────────── -->
  <section id="contact" class="section-contact" aria-label="Kontakt">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-form-wrap">
          <div class="reveal-up">
            <p class="section-eyebrow" data-i18n="contact.eyebrow">Kontakt</p>
            <h2 class="section-headline section-headline--light"
              data-cms-de="<%= (pages.homepage.ctaHeadline && pages.homepage.ctaHeadline.de) || 'Starten Sie Ihr Projekt' %>"
              data-cms-en="<%= (pages.homepage.ctaHeadline && pages.homepage.ctaHeadline.en) || 'Start your project' %>"
            ><%= (pages.homepage.ctaHeadline && pages.homepage.ctaHeadline.de) || 'Starten Sie Ihr Projekt' %></h2>
            <p class="section-sub section-sub--light" style="margin-bottom:2rem;"
              data-cms-de="<%= (pages.homepage.ctaSubtext && pages.homepage.ctaSubtext.de) || 'Vereinbaren Sie noch heute ein kostenloses Erstgespräch.' %>"
              data-cms-en="<%= (pages.homepage.ctaSubtext && pages.homepage.ctaSubtext.en) || 'Schedule a free initial consultation today.' %>"
            ><%= (pages.homepage.ctaSubtext && pages.homepage.ctaSubtext.de) || 'Vereinbaren Sie noch heute ein kostenloses Erstgespräch.' %></p>
          </div>
          <form class="contact-form reveal-up" id="contactForm" novalidate>
            <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;height:0;width:0;">
            <div class="form-row">
              <div class="form-field">
                <label class="form-label" for="contactName" data-i18n="contact.name_label">Name</label>
                <input class="form-input" id="contactName" name="name" type="text" autocomplete="name" data-i18n-placeholder="contact.name" placeholder="Ihr Name" required>
              </div>
              <div class="form-field">
                <label class="form-label" for="contactEmail" data-i18n="contact.email_label">E-Mail</label>
                <input class="form-input" id="contactEmail" name="email" type="email" autocomplete="email" data-i18n-placeholder="contact.email" placeholder="E-Mail-Adresse" required>
              </div>
            </div>
            <div class="form-field">
              <label class="form-label" for="contactSubject" data-i18n="contact.subject_label">Betreff</label>
              <input class="form-input" id="contactSubject" name="subject" type="text" data-i18n-placeholder="contact.subject" placeholder="Betreff">
            </div>
            <div class="form-field">
              <label class="form-label" for="contactMessage" data-i18n="contact.message_label">Nachricht</label>
              <textarea class="form-textarea" id="contactMessage" name="message" data-i18n-placeholder="contact.message" placeholder="Ihre Nachricht" required></textarea>
            </div>
            <div class="form-submit">
              <button type="submit" class="btn btn-primary" id="contactSubmit">
                <span data-i18n="contact.submit">Nachricht senden</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
              </button>
              <span class="form-success" id="formSuccess">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                <span data-i18n="contact.success">Nachricht gesendet!</span>
              </span>
            </div>
          </form>
        </div>

        <div class="contact-info reveal-right">
          <div class="contact-info-block">
            <p class="contact-info-label" data-i18n="contact.address_label">Adresse</p>
            <address class="contact-info-value" style="font-style:normal;">
              Sternstraße 68<br>42275 Wuppertal<br>Deutschland
            </address>
          </div>
          <div class="contact-info-block">
            <p class="contact-info-label" data-i18n="contact.phone_label">Telefon</p>
            <p class="contact-info-value"><a href="tel:+4920274722117">+49 (0)202 74 72 21 17</a></p>
          </div>
          <div class="contact-info-block">
            <p class="contact-info-label" data-i18n="contact.email_label">E-Mail</p>
            <p class="contact-info-value"><a href="mailto:info@acopa.de">info@acopa.de</a></p>
          </div>
          <div class="contact-socials">
            <%- include('partials/_social-icons') %>
          </div>
        </div>
      </div>
    </div>
  </section>

</main>

<!-- Mobile Sticky CTA (nur auf Mobile sichtbar) -->
