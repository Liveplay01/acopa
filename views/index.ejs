<%- include('partials/_head', { title: 'ACOPA GmbH – Managementberatung & IT-Consulting', description: 'ACOPA GmbH – Ihr Partner für SAP Consulting, Digitalisierung, Cybersecurity und digitale Transformation. Mehrwert durch digitale Prozesse.' }) %>
<%- include('partials/_nav') %>

<main id="main-content">

  <!-- ── HERO ─────────────────────────────────────────────── -->
  <section id="hero" class="section-hero" aria-label="Hero">
