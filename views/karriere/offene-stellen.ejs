<%- include('../partials/_head', { title: 'Offene Stellen – ACOPA GmbH', description: 'Aktuelle Stellenangebote bei ACOPA: SAP Consultant SCM/IBP, PP/DS, ABAP/Fiori Developer. Jetzt bewerben und Teil des ACOPA Experten-Netzwerks werden.' }) %>
<%- include('../partials/_nav') %>

<main id="main-content">

  <section class="page-hero">
    <div class="page-hero-bg" style="background-image:url('https://images.unsplash.com/photo-1600880292203-757bb62b4baf?auto=format&fit=crop&w=1920&q=80')"></div>
    <div class="page-hero-overlay"></div>
    <div class="page-hero-accent"></div>
    <div class="page-hero-shape"></div>
    <div class="container">
      <nav class="breadcrumb"><a href="/">Home</a><span>/</span><a href="/karriere">Karriere</a><span>/</span><span>Offene Stellen</span></nav>
      <p class="section-eyebrow" style="color:var(--color-primary);margin-bottom:1rem;">Jetzt bewerben</p>
      <h1 class="page-hero-title">Offene <span class="accent">Stellen.</span></h1>
      <p class="page-hero-sub">Starten Sie Ihre Karriere bei ACOPA – mit spannenden SAP- und IT-Projekten, einem starken Team und echten Entwicklungsmöglichkeiten. Wir suchen Experten, die mit Leidenschaft an die Sache rangehen.</p>
    </div>
  </section>

  <section class="content-section content-section--alt">
    <div class="container">
      <div class="section-header reveal-up">
        <p class="section-eyebrow">Aktuelle Ausschreibungen</p>
        <h2 class="section-headline">Wir suchen Experten wie Sie</h2>
        <p class="section-sub">Alle Positionen bieten flexible Arbeitszeiten, Homeoffice-Möglichkeiten und echte Entwicklungschancen innerhalb unseres wachsenden Netzwerks.</p>
      </div>

      <div class="jobs-list">

        <% if (jobs.length === 0) { %>
          <div style="text-align:center;padding:3rem 0;">
            <p style="color:var(--color-gray-500);">Derzeit keine offenen Stellen. Schicken Sie uns gerne eine Initiativbewerbung.</p>
          </div>
        <% } %>

        <% jobs.forEach(function(job) { %>
          <div class="job-card reveal-up" style="display:flex;flex-direction:column;gap:1.5rem;cursor:default;">
            <div style="display:grid;grid-template-columns:1fr auto;gap:1.5rem;align-items:start;">
              <div class="job-card-info">
                <div class="job-card-header">
                  <span class="job-card-title"><%= job.title %></span>
                  <span class="job-badge"><%= job.badge || 'Vollzeit' %></span>
                </div>
                <div class="job-card-meta" style="margin-top:0.5rem;">
                  <span class="job-meta-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    <%= job.location || 'Wuppertal / Remote' %>
                  </span>
                  <span class="job-meta-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
                    <%= job.type || 'Vollzeit' %>
                  </span>
                  <span class="job-meta-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
                    <%= job.start || 'Ab sofort' %>
                  </span>
                </div>
              </div>
              <a href="mailto:karriere@acopa.de?subject=<%= encodeURIComponent(job.emailSubject || 'Bewerbung ' + job.title) %>" class="btn btn-primary" style="white-space:nowrap;">Jetzt bewerben</a>
            </div>
            <p style="font-size:var(--text-sm);color:var(--color-gray-600);line-height:1.7;"><%= job.description %></p>
            <% if (job.tags && job.tags.length) { %>
              <div style="display:flex;gap:0.6rem;flex-wrap:wrap;">
                <% job.tags.forEach(function(tag) { %><span class="value-tag"><%= tag %></span><% }); %>
              </div>
            <% } %>
          </div>
        <% }); %>

      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="container">
      <div style="max-width:700px;margin:0 auto;text-align:center;" class="reveal-up">
        <p class="section-eyebrow" style="justify-content:center;">Kein passendes Angebot?</p>
        <h2 class="section-headline">Initiativbewerbung</h2>
        <p class="section-sub" style="margin:1rem auto 2rem;">Sie sind Experte auf Ihrem Gebiet, aber finden keine passende Ausschreibung? Wir freuen uns auf Ihre Initiativbewerbung! Beschreiben Sie uns kurz, wer Sie sind und was Sie bei ACOPA einbringen möchten.</p>
        <a href="mailto:karriere@acopa.de?subject=Initiativbewerbung" class="btn btn-primary">
          Initiativbewerbung senden
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        </a>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <p class="section-eyebrow cta-eyebrow">Mehr über ACOPA</p>
      <h2 class="cta-title">Lernen Sie uns besser kennen.</h2>
      <p class="cta-sub">Entdecken Sie unsere Unternehmenskultur, Werte und was eine Karriere bei ACOPA besonders macht.</p>
      <div class="cta-buttons">
        <a href="/karriere" class="btn btn-primary">Zur Karriere-Übersicht</a>
        <a href="/acopa" class="btn btn-ghost">Über ACOPA</a>
      </div>
    </div>
  </section>

</main>

<%- include('../partials/_footer') %>
