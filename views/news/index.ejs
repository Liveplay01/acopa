<%- include('../partials/_head', { title: 'News & Insights – ACOPA GmbH', description: 'Aktuelle Beiträge, Insights und Expertenwissen rund um SAP, Digitalisierung, Supply Chain und IT-Security von den ACOPA Experten.' }) %>
<%- include('../partials/_nav') %>

<main id="main-content">

  <section class="page-hero">
    <div class="page-hero-bg" style="background-image:url('https://images.unsplash.com/photo-1504711434969-e33886168f5c?auto=format&fit=crop&w=1920&q=80')"></div>
    <div class="page-hero-overlay"></div>
    <div class="page-hero-accent"></div>
    <div class="page-hero-shape"></div>
    <div class="container">
      <nav class="breadcrumb"><a href="/">Home</a><span>/</span><span>News & Insights</span></nav>
      <p class="section-eyebrow" style="color:var(--color-primary);margin-bottom:1rem;">Expertenwissen</p>
      <h1 class="page-hero-title">News &amp; <span class="accent">Insights.</span></h1>
      <p class="page-hero-sub">Aktuelles Fachwissen, Projekterfahrungen und Trends aus der Welt der digitalen Transformation – direkt von unseren ACOPA-Experten.</p>
    </div>
  </section>

  <section class="content-section">
    <div class="container">

      <% if (categories && categories.length > 1) { %>
      <div class="news-filter" role="navigation" aria-label="Kategorie-Filter">
        <a href="/news" class="news-filter-btn<%= !activeCategory ? ' active' : '' %>">Alle</a>
        <% categories.forEach(function(cat) { %>
        <a href="/news?category=<%= encodeURIComponent(cat) %>" class="news-filter-btn<%= activeCategory === cat ? ' active' : '' %>"><%= cat %></a>
        <% }); %>
      </div>
      <% } %>

      <% if (posts.length === 0) { %>
        <div style="text-align:center;padding:4rem 0;">
          <p style="color:var(--color-gray-500);font-size:var(--text-lg);">
            <% if (activeCategory) { %>Keine Beiträge in der Kategorie "<%= activeCategory %>".<% } else { %>Noch keine Beiträge vorhanden.<% } %>
          </p>
          <% if (activeCategory) { %><a href="/news" class="btn btn-outline" style="margin-top:1.5rem;">Alle Beiträge anzeigen</a><% } %>
        </div>
      <% } else { %>

        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;">

          <% posts.forEach(function(post) { %>
            <article class="news-card reveal-up" style="display:flex;flex-direction:column;">
              <div class="news-card-image" style="position:relative;overflow:hidden;border-radius:var(--radius-md) var(--radius-md) 0 0;aspect-ratio:16/9;">
                <img
                  src="<%= post.imageUrl %>"
                  alt="<%= post.title.de %>"
                  loading="lazy"
                  style="width:100%;height:100%;object-fit:cover;transition:transform 0.4s ease;"
                >
                <span class="news-card-category" style="position:absolute;top:1rem;left:1rem;"><%= post.category %></span>
              </div>
              <div class="news-card-body" style="flex:1;display:flex;flex-direction:column;padding:1.5rem;background:var(--color-surface);border:1px solid var(--color-gray-200);border-top:none;border-radius:0 0 var(--radius-md) var(--radius-md);">
                <time class="news-card-date" datetime="<%= post.date %>" style="font-size:var(--text-xs);color:var(--color-gray-400);font-family:var(--font-mono);letter-spacing:0.05em;display:block;margin-bottom:0.5rem;">
                  <%= new Date(post.date).toLocaleDateString('de-DE', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                </time>
                <h2 class="news-card-title" style="font-family:var(--font-display);font-size:var(--text-xl);line-height:1.3;margin:0 0 0.75rem;color:var(--color-foreground);"><%= post.title.de %></h2>
                <p class="news-card-excerpt" style="font-size:var(--text-sm);color:var(--color-gray-600);line-height:1.7;flex:1;"><%= (post.excerpt && post.excerpt.de) || post.content.de.substring(0, 130) + '…' %></p>
                <div class="news-card-footer" style="display:flex;align-items:center;justify-content:space-between;margin-top:1.25rem;padding-top:1rem;border-top:1px solid var(--color-gray-200);">
                  <span class="news-card-author" style="font-size:var(--text-xs);color:var(--color-gray-500);">von <%= post.author %></span>
                  <a href="/news/<%= post.slug %>" class="news-card-link" style="display:flex;align-items:center;gap:0.35rem;font-size:var(--text-sm);font-weight:600;color:var(--color-primary);text-decoration:none;">
                    Weiterlesen
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
                  </a>
                </div>
              </div>
            </article>
          <% }); %>

        </div>

      <% } %>

    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <p class="section-eyebrow cta-eyebrow">Newsletter</p>
      <h2 class="cta-title">Bleiben Sie auf dem Laufenden.</h2>
      <p class="cta-sub">Erhalten Sie neue Insights und Expertenbeiträge direkt in Ihr Postfach – natürlich ohne Spam.</p>
      <div class="cta-buttons">
        <a href="mailto:info@acopa.de?subject=Newsletter-Anmeldung" class="btn btn-primary">Newsletter abonnieren</a>
        <a href="/#contact" class="btn btn-ghost">Kontakt aufnehmen</a>
      </div>
    </div>
  </section>

</main>

<%- include('../partials/_footer') %>
