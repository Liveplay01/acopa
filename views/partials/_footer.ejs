<!-- Newsletter -->
<section class="newsletter-section" aria-label="Newsletter">
  <div class="container">
    <div class="newsletter-inner">
      <div class="newsletter-text">
        <p class="newsletter-title">Monatliche SAP & IT Insights</p>
        <p class="newsletter-sub">Praxiswissen für digitale Entscheider – kein Spam, jederzeit abmeldbar.</p>
      </div>
      <form class="newsletter-form" id="newsletterForm" novalidate>
        <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;height:0;width:0;">
        <input class="newsletter-input" type="email" name="email" placeholder="Ihre E-Mail-Adresse" required aria-label="E-Mail für Newsletter">
        <button type="submit" class="btn btn-primary" style="white-space:nowrap;">
          Anmelden
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 2L11 13M22 2L15 22l-4-9-9-4 20-7z"/></svg>
        </button>
      </form>
      <div class="newsletter-success" id="newsletterSuccess" aria-live="polite">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        Erfolgreich angemeldet!
      </div>
    </div>
  </div>
</section>

<footer class="site-footer" aria-label="Footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <img src="/assets/AcopaLogo.png" alt="ACOPA" class="footer-logo">
        <p class="footer-tagline"
          data-cms-de="<%= (pages && pages.footer && pages.footer.tagline && pages.footer.tagline.de) || 'Mehrwert durch digitale Prozesse.' %>"
          data-cms-en="<%= (pages && pages.footer && pages.footer.tagline && pages.footer.tagline.en) || 'Value through digital processes.' %>"
        ><%= (pages && pages.footer && pages.footer.tagline && pages.footer.tagline.de) || 'Mehrwert durch digitale Prozesse.' %></p>
        <p class="footer-tagline" style="margin-top:0.25rem;font-size:0.7rem;letter-spacing:0.08em;opacity:0.4;text-transform:uppercase;">Digital · Sustainable · Passionately Curious</p>
      </div>

      <nav class="footer-col" aria-label="Leistungen">
        <p class="footer-col-title" data-i18n="footer.services">Leistungen</p>
        <a href="/service/sap-beratung"    class="footer-link">SAP Consulting</a>
        <a href="/service/digitalisierung" class="footer-link">Digitalisierung</a>
        <a href="/service/cybersecurity"   class="footer-link">Cybersecurity</a>
        <a href="/service/sustainability"  class="footer-link">Green Tech</a>
        <a href="/service/supply-chain"    class="footer-link">Supply Chain</a>
      </nav>

      <nav class="footer-col" aria-label="Unternehmen">
        <p class="footer-col-title" data-i18n="footer.company">Unternehmen</p>
        <a href="/acopa"              class="footer-link">Über uns</a>
        <a href="/acopa/referenzen"   class="footer-link">Kunden</a>
        <a href="/news"               class="footer-link">News</a>
        <a href="/karriere"           class="footer-link">Karriere</a>
      </nav>

      <nav class="footer-col" aria-label="Kontakt">
        <p class="footer-col-title" data-i18n="nav.contact">Kontakt</p>
        <a href="tel:+4920274722117"    class="footer-link">+49 (0)202 74 72 21 17</a>
        <a href="mailto:info@acopa.de"  class="footer-link">info@acopa.de</a>
        <a href="/impressum"  class="footer-link" data-i18n="footer.impressum">Impressum</a>
        <a href="/datenschutz" class="footer-link" data-i18n="footer.privacy">Datenschutz</a>
      </nav>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy" data-i18n="footer.copyright">© 2026 ACOPA GmbH & Co. KG. Alle Rechte vorbehalten.</p>
      <div class="footer-bottom-right">
        <%- include('./_social-icons', { socialClass: 'social-links--footer' }) %>
        <div class="footer-legal">
          <a href="/impressum"   data-i18n="footer.impressum">Impressum</a>
          <a href="/datenschutz" data-i18n="footer.privacy">Datenschutz</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<!-- Cookie Banner -->
<div class="cookie-banner" id="cookieBanner" role="dialog" aria-label="Cookie-Hinweis" aria-live="polite">
  <div class="cookie-banner-inner">
    <p class="cookie-text">
      Diese Website verwendet ausschließlich technisch notwendige Cookies – keine Tracking- oder Marketing-Cookies.
      <a href="/datenschutz" class="cookie-link">Datenschutzerklärung</a>
    </p>
    <button class="cookie-accept" id="cookieAccept" aria-label="Cookie-Hinweis schließen">Verstanden</button>
  </div>
</div>

