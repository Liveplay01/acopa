  <!-- 3-Phasen Approach -->
  <section class="content-section">
    <div class="container">
      <div class="section-header reveal-up" style="max-width:600px;">
        <p class="section-eyebrow">Unser Vorgehen</p>
        <h2 class="section-headline">In drei Phasen zum Ziel</h2>
